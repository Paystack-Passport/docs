{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "GlobalStack API",
  "colors": {
    "primary": "#0E141B",
    "light": "#F2F1EE",
    "dark": "#0E141B"
  },
  "background": {
    "color": {
      "light": "#F2F1EE",
      "dark": "#0E0E0D"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "api-reference/openapi.json"
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "href": "https://globalstack.io",
          "icon": "globe"
        },
        {
          "anchor": "Dashboard",
          "href": "https://dashboard.globalstack.io",
          "icon": "gauge"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Home",
        "href": "https://globalstack.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.globalstack.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://globalstack.io"
    }
  }
}
