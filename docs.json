{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "GlobalStack API",
  "colors": {
    "primary": "#0E141B",
    "light": "#FFFFFF",
    "dark": "#0E141B"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0E0E0D"
    }
  },
  "fonts": {
    "family": "Geist",
    "heading": {
      "family": "Geist",
      "weight": 600
    }
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "🏠 Home",
        "pages": ["index"]
      },
      {
        "tab": "🚀 Get Started",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["quickstart"]
          }
        ]
      },
      {
        "tab": "🛠️ Developer Platform",
        "groups": [
          {
            "group": "Platform",
            "pages": [
              "api-reference/authentication",
              "api-reference/idempotency",
              "api-reference/pagination",
              "webhooks/verify-signatures",
              "errors",
              "api-reference/failure-reasons"
            ]
          }
        ]
      },
      {
        "tab": "📖 API Reference",
        "openapi": "api-reference/openapi.json"
      }
    ]
  },
  "redirects": [
    { "source": "/api-reference/errors", "destination": "/errors" }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Home",
        "href": "https://globalstack.io"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.globalstack.io"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "download-spec",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://globalstack.io"
    }
  }
}
