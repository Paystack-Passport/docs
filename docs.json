{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "GlobalStack API",
  "colors": {
    "primary": "#0E141B",
    "light": "#F2F1EE",
    "dark": "#0E141B"
  },
  "background": {
